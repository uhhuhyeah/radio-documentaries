# Copy to .env (gitignored) and fill in. Consumed by the API-touching stages.

# --- Navidrome / Subsonic (navidrome.py: resolve IDs, scan, create playlist) ---
# Read-only use of the shared `david` account. NEVER rotate it from this repo
# (it fans out to SUB/WAVE + Homepage — see the vault note).
NAVIDROME_URL=http://192.168.1.110:4533
NAVIDROME_USER=david
NAVIDROME_PASS=

# --- ElevenLabs (render.py: TTS) ---
# DEDICATED docs key — do NOT reuse the live station's "SUBWAVE" key.
# Setup TODO: create a restricted key on David's ElevenLabs account (see
# producer-guide.md → ElevenLabs) and paste it here.
ELEVENLABS_API_KEY=

# Per-episode credit cap for the render hard-stop (chosen-model credits). Overrides
# settings.toml [budget] per_episode_cap.
DOCS_PER_EPISODE_CAP=15000

# --- OpenRouter (the agents: Producer + research/write sub-agents) ---
OPENROUTER_API_KEY=

# --- Brave Search API (the Researcher's web search; free tier ~2k/mo) ---
# Get a key at https://brave.com/search/api/ (Data for Search, free plan).
BRAVE_API_KEY=

# --- NAS staging (pipeline LXC ONLY — leave unset on a dev box, which uses SSH) ---
# On the pipeline LXC the Music share is bind-mounted read-write, so stage.ts copies to it
# directly instead of rsync-over-SSH. Uncomment both on the LXC.
#DOCS_NAS_LOCAL=1
#DOCS_NAS_MUSIC_DIR=/mnt/music/subwave-documentaries

# --- MCP server (mcp.ts: exposes documentaryTools to Hermes over Streamable HTTP) ---
# Bearer token Hermes must present as `Authorization: Bearer <token>`. REQUIRED — the
# server fails closed (refuses to start) if unset. Generate a long random value, e.g.
#   openssl rand -hex 32
# and register it on Hermes with: hermes mcp add subwave --url http://<host>:8848/mcp --auth header
DOCS_MCP_TOKEN=
